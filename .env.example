# Optional local overrides (copy to .env and load with direnv/dotenv if you like)
# FLASK_SECRET_KEY=change-me
# DATA_DIR=./data
# RSS_AUTO_PULL=1
# RSS_PULL_INTERVAL_MINUTES=60
#
# API keys live in gitignored JSON files (not .env):
#   congress_api.json          — Congress.gov
#   federal_register_api.json  — api.data.gov (Regulations.gov; FR API usually needs no key)
